{
  "name": "harnessnation-plus",
  "description": "Enhance your HarnessNation experience with these client-side add-ons and fixes!",
  "version": "3.13.0",
  "repository": "https://github.com/tfrizzell/harnessnation-plus.git",
  "author": "Trevor Frizzell <trevor@frizzell.ca>",
  "license": "MIT",
  "private": true,
  "scripts": {
    "build": "gulp build",
    "build:chrome": "gulp build:chrome",
    "build:debug": "gulp build:debug",
    "build:edge": "gulp build:edge",
    "build:firefox": "gulp build:firefox",
    "clean": "gulp clean",
    "debug": "pnpm debug:chrome",
    "debug:chrome": "gulp debug:chrome && pnpm watch",
    "debug:edge": "gulp debug:edge && pnpm watch",
    "debug:firefox": "gulp debug:firefox",
    "package": "gulp package",
    "package:all": "gulp package:all",
    "package:chrome": "gulp package:chrome",
    "package:edge": "gulp package:edge",
    "package:firefox": "gulp package:firefox",
    "test": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.src.json --noEmit && tsc -p tsconfig.test.json --noEmit",
    "watch": "tsc --watch --sourceMap"
  },
  "devDependencies": {
    "@types/chrome": "^0.2.0",
    "@types/node": "^26.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "blob-polyfill": "^9.0.20240710",
    "del": "^8.0.1",
    "fake-indexeddb": "^6.0.0",
    "firebase": "12.15.0",
    "gulp": "^5.0.1",
    "gulp-rename": "^2.0.0",
    "gulp-typescript": "^6.0.0-alpha.1",
    "gulp-zip": "^6.1.0",
    "jsdom": "^29.1.1",
    "pdf-lib": "1.17.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "**/minimatch": "^5.1.6"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b"
}