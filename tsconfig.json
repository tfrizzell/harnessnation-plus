{
    "compilerOptions": {
        "rootDir": "src",
        "outDir": "dist",
        "strict": true,
        "target": "esnext",
        "module": "esnext",
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "types": ["node", "jest", "chrome"],
        "paths": {
            "firebase/app": ["./node_modules/@firebase/app/dist/app-public.d.ts"],
            "firebase/firestore": ["./node_modules/@firebase/firestore/dist/index.d.ts"],
            "@firebase/*": ["./node_modules/@firebase/*"],
        },
    },
    "include": [
        "src/**/*.ts",
        "types/**/*.ts",
    ],
    "exclude": [
        "dist",
        "node_modules",
    ],
    "watchOptions": {
        "watchFile": "DynamicPriorityPolling",
        "watchDirectory": "DynamicPriorityPolling",
    },
}